{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalImage",
  "version": "0.2.0",
  "identifier": "com.localimage.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1448",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalImage",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 560,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$HOME/**",
          "$DESKTOP/**",
          "$DOWNLOAD/**",
          "$PICTURE/**",
          "$DOCUMENT/**",
          "$VIDEO/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
